rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation Blueprint for Deal
    function isValidDeal(data) {
      return data.keys().hasAll(['ticket', 'type', 'volume', 'price', 'time', 'profit', 'commission', 'swap', 'symbol', 'magic', 'isPublic', 'ownerId'])
        && (data.keys().size() == 12 || (data.keys().size() == 13 && data.keys().hasAll(['account'])))
        && (data.account == null || data.account is number)
        && data.ticket is string && data.ticket.size() > 0 && data.ticket.size() <= 64
        && data.type is number
        && data.volume is number
        && data.price is number
        && data.time is number
        && data.profit is number
        && data.commission is number
        && data.swap is number
        && data.symbol is string && data.symbol.size() <= 32
        && data.magic is number
        && data.isPublic is bool
        && data.ownerId is string && data.ownerId == request.auth.uid;
    }

    // Validation Blueprint for AppSettings
    function isValidAppSettings(data) {
      return data.keys().hasAny(['title', 'logoUrl', 'accounts', 'links'])
        && (data.title == null || (data.title is string && data.title.size() <= 64))
        && (data.logoUrl == null || (data.logoUrl is string && data.logoUrl.size() <= 2048))
        && (data.accounts == null || data.accounts is map)
        && (data.links == null || data.links is map);
    }

    // Match rules for Settings
    match /settings/{settingId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn()
                    && isValidId(settingId)
                    && isValidAppSettings(incoming());
      allow update: if isSignedIn()
                    && isValidId(settingId)
                    && isValidAppSettings(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'logoUrl', 'accounts', 'links']);
      allow delete: if false; // do not allow delete
    }

    // Validation Blueprint for Account
    function isValidAccount(data) {
      return data.keys().hasAll(['account', 'maxDrawdown', 'maxDrawdownPct', 'ownerId'])
        && data.keys().size() == 4
        && data.account is number
        && data.maxDrawdown is number
        && data.maxDrawdownPct is number
        && data.ownerId is string && data.ownerId == request.auth.uid;
    }

    // Match rules for Accounts
    match /accounts/{accountId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow list: if isSignedIn() && existing().ownerId == request.auth.uid;
      allow create: if isSignedIn()
                    && isValidId(accountId)
                    && isValidAccount(incoming())
                    && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn()
                    && isValidId(accountId)
                    && isValidAccount(incoming())
                    && incoming().ownerId == existing().ownerId
                    && incoming().account == existing().account
                    && incoming().diff(existing()).affectedKeys().hasOnly(['maxDrawdown', 'maxDrawdownPct']);
      allow delete: if false;
    }

    // Match rules for Deals
    match /deals/{dealId} {
      allow get: if existing().isPublic == true || 
                 (isSignedIn() && existing().ownerId == request.auth.uid);
      
      allow list: if existing().isPublic == true || 
                  (isSignedIn() && existing().ownerId == request.auth.uid);

      allow create: if isSignedIn() 
                    && isValidId(dealId) 
                    && isValidDeal(incoming()) 
                    && incoming().ownerId == request.auth.uid;
                    
      allow update: if isSignedIn()
                    && isValidId(dealId)
                    && isValidDeal(incoming())
                    && incoming().ownerId == existing().ownerId  // Immutability Check
                    && incoming().ticket == existing().ticket
                    && incoming().diff(existing()).affectedKeys().hasOnly([
                        'type', 'volume', 'price', 'time', 'profit', 
                        'commission', 'swap', 'symbol', 'magic', 'isPublic', 'account'
                       ]);

      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }
  }
}
